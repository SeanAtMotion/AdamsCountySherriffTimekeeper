# Build the SPA with the API URL your users will call.
#
# Same site as the API (recommended): IIS or App Service serves the API and static files under one host;
# the UI uses relative /api and the cookie stays first-party.
VITE_API_BASE=/api

# If the UI is on a different origin than the API, set the full API base (must be listed in the API Cors:Origins).
# VITE_API_BASE=https://timekeeping-api.county.gov/api
